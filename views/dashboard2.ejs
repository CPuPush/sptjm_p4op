<div class="container-fluid mt-4 px-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">Rekapitulasi SPTJM (Mode Filter)</h2>
            <p class="text-muted small">Monitoring data masuk dan nominal pendebetan berkas sekolah.</p>
        </div>
        <a href="/sptjm/add" class="btn btn-warning fw-bold px-4 shadow-sm">+ Input Data Baru</a>
    </div>

    <div class="card shadow-sm border-0 mb-4 bg-light">
        <div class="card-body">
            <form action="/dashboard2" method="GET" class="row g-3">
                <div class="col-md-2">
                    <label class="form-label small fw-bold text-muted">Filter Tanggal</label>
                    <input type="date" name="date" id="filterDate" class="form-control" value="<%= currentDate %>">
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-bold text-muted">Cari NPSN</label>
                    <input type="text" name="npsn" class="form-control" placeholder="Contoh: 2010..." value="<%= currentNpsn %>">
                </div>
                <div class="col-md-4">
                    <label class="form-label small fw-bold text-muted">Cari Nama Sekolah</label>
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-search"></i></span>
                        <input type="text" name="q" class="form-control" placeholder="Ketik nama sekolah..." value="<%= currentSearch %>">
                    </div>
                </div>
                <div class="col-md-4 d-flex align-items-end gap-2">
                    <button type="submit" class="btn btn-primary px-4 fw-bold">
                        <i class="bi bi-filter"></i> Terapkan Filter
                    </button>
                    <% if (currentDate || currentSearch || currentNpsn) { %>
                        <a href="/dashboard2" class="btn btn-outline-secondary px-3">
                            <i class="bi bi-x-circle"></i> Reset
                        </a>
                    <% } %>
                </div>
            </form>
        </div>
    </div>

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th class="ps-3 text-center">No</th>
                            <th>Sekolah & NPSN</th>
                            <th>No. Surat</th>
                            <th>Tgl Terima</th>
                            <th>Rincian (Siswa/SPP/Bln)</th>
                            <th>Total Dana</th>
                            <th>Petugas</th>
                            <th class="text-center">Status</th>
                            <th class="text-center">Hapus</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (data && data.length > 0) { %>
                            <% data.forEach((item) => { %>
                                <tr>
                                    <td class="ps-3 text-center"><strong><%= item.no_urut_harian %></strong></td>
                                    <td>
                                        <a href="/sptjm/<%= item.id %>" class="fw-bold text-primary text-decoration-none text-uppercase">
                                            <%= item.AlokasiBantuan?.MasterSekolah?.nama_sekolah %>
                                        </a>
                                        <div class="small text-muted">
                                            NPSN: <%= item.AlokasiBantuan?.MasterSekolah?.npsn %> | 
                                            Jenjang: <span class="badge bg-light text-dark border"><%= item.AlokasiBantuan?.MasterSekolah?.jenjang %></span>
                                        </div>
                                    </td>
                                    <td><code class="text-dark text-uppercase"><%= item.no_surat %></code></td>
                                    <td class="small">
                                        <%= new Date(item.tgl_terima).toLocaleDateString('id-ID', { day: '2-digit', month: 'short', year: 'numeric' }) %>
                                    </td>
                                    <td class="small">
                                        <i class="bi bi-people"></i> <%= item.jmlh_siswa %> Siswa<br>
                                        <i class="bi bi-cash"></i> Rp <%= parseInt(item.spp).toLocaleString('id-ID') %> / <%= item.bulan %> Bln
                                    </td>
                                    <td>
                                        <span class="fw-bold text-success">
                                            Rp <%= parseInt(item.total).toLocaleString('id-ID') %>
                                        </span>
                                    </td>
                                    <td class="small text-muted">
                                        <i class="bi bi-person-circle"></i> <%= item.User?.username %>
                                    </td>
                                    <td class="text-center">
                                        <div class="form-check form-switch d-flex justify-content-center">
                                            <input class="form-check-input shadow-none" type="checkbox" role="switch" 
                                                id="switch-<%= item.id %>" 
                                                style="cursor: pointer; width: 2.2em; height: 1.1em;"
                                                <%= item.status_ambil ? 'checked' : '' %>
                                                onchange="toggleStatus('<%= item.id %>', '<%= item.AlokasiBantuan?.MasterSekolah?.nama_sekolah %>')">
                                            <label class="form-check-label ms-2 small fw-bold <%= item.status_ambil ? 'text-success' : 'text-warning' %>" for="switch-<%= item.id %>">
                                                <%= item.status_ambil ? 'Selesai' : 'Proses' %>
                                            </label>
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        <button class="btn btn-sm btn-outline-danger border-0" 
                                                onclick="deleteTransaction('<%= item.id %>', '<%= item.AlokasiBantuan?.MasterSekolah?.nama_sekolah %>')"
                                                title="Hapus Data">
                                            <i class="bi bi-trash3-fill"></i>
                                        </button>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="9" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                    Belum ada data ditemukan untuk kriteria ini.
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script>
    // 1. Logika Default Date di Frontend
    window.addEventListener('DOMContentLoaded', (event) => {
        const dateInput = document.getElementById('filterDate');
        if (!dateInput.value) {
            const today = new Date().toLocaleDateString('en-CA');        }
    });

    // 2. Logika Toggle Status (PATCH)
    async function toggleStatus(id, namaSekolah) {
        try {
            const res = await fetch(`/sptjm/pickup/${id}`, {
                method: 'PATCH',
                headers: { 'Content-Type': 'application/json' }
            });
            const result = await res.json();
            if (result.status === 'success') {
                window.location.reload(); 
            } else {
                alert("Gagal memperbarui status: " + result.message);
                window.location.reload();
            }
        } catch (err) {
            console.error(err);
            alert("Terjadi kesalahan koneksi.");
            window.location.reload();
        }
    }

    // 3. BARU: Logika Hapus Transaksi (DELETE)
    async function deleteTransaction(id, namaSekolah) {
        const confirmDelete = confirm(`Apakah Anda yakin ingin menghapus data SPTJM ${namaSekolah}? Tindakan ini tidak dapat dibatalkan.`);
        
        if (confirmDelete) {
            try {
                // Memanggil API delete yang sudah kita buat di backend
                const res = await fetch(`/sptjm/${id}`, {
                    method: 'DELETE',
                    headers: { 'Content-Type': 'application/json' }
                });

                const result = await res.json();

                if (result.status === 'success') {
                    alert("Data Berhasil Dihapus!");
                    window.location.reload(); // Refresh dashboard untuk melihat perubahan
                } else {
                    alert("Gagal menghapus data: " + result.message);
                }
            } catch (err) {
                console.error(err);
                alert("Terjadi kesalahan koneksi saat mencoba menghapus data.");
            }
        }
    }
</script>