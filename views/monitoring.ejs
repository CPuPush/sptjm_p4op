<div class="container-fluid px-4 mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h3 class="fw-bold mb-0"><i class="bi bi-display me-2 text-primary"></i>Monitoring Realisasi SPTJM</h3>
            <p class="text-muted small mb-0">Wilayah Jakarta Barat - Periode: Tahap <%= filter.tahap %> <%= filter.tahun %></p>
        </div>
        
        <form action="/monitoring" method="GET" class="d-flex gap-2 bg-white p-2 rounded shadow-sm border">
            <select name="tahun" class="form-select form-select-sm" style="width: 120px;">
                <% years.forEach(y => { %>
                    <option value="<%= y.tahun %>" <%= filter.tahun == y.tahun ? 'selected' : '' %>>Tahun <%= y.tahun %></option>
                <% }) %>
            </select>

            <select name="tahap" class="form-select form-select-sm" style="width: 100px;">
                <% stages.forEach(s => { %>
                    <option value="<%= s.tahap %>" <%= filter.tahap == s.tahap ? 'selected' : '' %>>Tahap <%= s.tahap %></option>
                <% }) %>
            </select>

            <select name="status" class="form-select form-select-sm border-primary" style="width: 160px;">
                <option value="all" <%= filter.status == 'all' ? 'selected' : '' %>>-- Semua Status --</option>
                <option value="sudah" <%= filter.status == 'sudah' ? 'selected' : '' %>>✅ Sudah Usul</option>
                <option value="belum" <%= filter.status == 'belum' ? 'selected' : '' %>>❌ Belum Usul</option>
            </select>

            <button type="submit" class="btn btn-primary btn-sm px-3 shadow-sm">
                <i class="bi bi-filter"></i> Filter
            </button>
        </form>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-primary text-white p-3 h-100">
                <small class="fw-bold opacity-75">TOTAL SEKOLAH</small>
                <h2 class="fw-bold mb-0"><%= stats.totalSekolah %></h2>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-success text-white p-3 h-100">
                <small class="fw-bold opacity-75">SUDAH USUL</small>
                <h2 class="fw-bold mb-0"><%= stats.sudahUsul %></h2>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-warning text-dark p-3 h-100">
                <small class="fw-bold opacity-75">BELUM USUL</small>
                <h2 class="fw-bold mb-0"><%= stats.belumUsul %></h2>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm bg-dark text-white p-3 h-100">
                <small class="fw-bold opacity-75">PROGRES TOTAL</small>
                <h2 class="fw-bold mb-0"><%= stats.persentase %>%</h2>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white py-3 border-bottom d-flex justify-content-between align-items-center">
            <h6 class="mb-0 fw-bold">Daftar Status Sekolah Jakarta Barat</h6>
            <span class="badge bg-light text-dark border">Menampilkan: <%= data.length %> Sekolah</span>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light text-uppercase small fw-bold">
                        <tr>
                            <th class="ps-4" style="width: 40%;">Nama Sekolah</th>
                            <th class="text-center">Target Siswa</th>
                            <th class="text-center">Realisasi Siswa</th>
                            <th class="text-center">Status Usulan</th>
                            <th class="text-center">Aksi</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% if (data.length > 0) { %>
                            <% data.forEach(item => { %>
                                <tr>
                                    <td class="ps-4">
                                        <div class="fw-bold text-dark text-uppercase"><%= item.MasterSekolah?.nama_sekolah %></div>
                                        <small class="text-muted">NPSN: <%= item.MasterSekolah?.npsn %></small>
                                    </td>
                                    <td class="text-center">
                                        <span class="fw-medium"><%= item.jumlah_penerima %></span>
                                    </td>
                                    <td class="text-center">
                                        <span class="fw-medium text-primary">
                                            <%= item.SptjmTransaksis && item.SptjmTransaksis.length > 0 ? item.SptjmTransaksis[0].jmlh_siswa : 0 %>
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <% if(item.status_usulan) { %>
                                            <span class="badge bg-success-subtle text-success px-3 py-2">
                                                <i class="bi bi-check-circle-fill me-1"></i> SUDAH USUL
                                            </span>
                                        <% } else { %>
                                            <span class="badge bg-danger-subtle text-danger px-3 py-2">
                                                <i class="bi bi-x-circle-fill me-1"></i> BELUM USUL
                                            </span>
                                        <% } %>
                                    </td>
                                    <td class="text-center">
                                        <% if(item.status_usulan) { %>
                                            <a href="/dashboard?q=<%= item.MasterSekolah?.nama_sekolah %>" class="btn btn-sm btn-outline-primary shadow-sm px-3">
                                                Lihat Berkas
                                            </a>
                                        <% } else { %>
                                            <button class="btn btn-sm btn-outline-secondary disabled border-0" disabled>
                                                Belum Ada Data
                                            </button>
                                        <% } %>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="5" class="text-center py-5">
                                    <div class="text-muted">
                                        <i class="bi bi-folder-x fs-1"></i>
                                        <p class="mt-2">Tidak ada data sekolah yang ditemukan untuk filter ini.</p>
                                    </div>
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>