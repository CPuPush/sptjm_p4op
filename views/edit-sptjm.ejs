<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm border-0">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-pencil-square"></i> Edit Transaksi SPTJM</h5>
                </div>
                <div class="card-body p-4">
                    <form id="formEditSptjm">
                        <div class="mb-4 p-3 bg-light rounded border border-primary">
                            <label class="form-label fw-bold text-primary small text-uppercase">Informasi Sekolah & Periode</label>
                            <h5 class="fw-bold mb-2 text-dark"><%= data.AlokasiBantuan?.MasterSekolah?.nama_sekolah %></h5>
                            
                            <div class="row">
                                <div class="col-md-12">
                                    <label class="form-label small">Ubah Tahap / Tahun (Jika Salah Input):</label>
                                    <select name="AlokasiBantuanId" class="form-select border-primary shadow-sm" required>
                                        <% availablePeriods.forEach(p => { %>
                                            <option value="<%= p.id %>" <%= data.AlokasiBantuanId == p.id ? 'selected' : '' %>>
                                                Tahap <%= p.tahap %> - Tahun <%= p.tahun %> (<%= data.AlokasiBantuan?.MasterSekolah?.jenjang %>)
                                            </option>
                                        <% }) %>
                                    </select>
                                </div>
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label small fw-bold">Tanggal Terima Berkas</label>
                                <input type="date" name="tgl_terima" class="form-control" value="<%= data.tgl_terima.toISOString().split('T')[0] %>" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold">Nomor Surat</label>
                                <input type="text" name="no_surat" class="form-control" value="<%= data.no_surat %>" required>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold">Nama Penanggung Jawab</label>
                            <input type="text" name="nama" class="form-control" value="<%= data.nama %>" required>
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold">Nomor Telepon Operator</label>
                            <input type="text" name="no_telp" id="no_telp" class="form-control" value="<%= data.no_telp %>" placeholder="08xxxxxx">
                        </div>

                        <hr class="my-4">

                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label class="form-label small fw-bold">Jumlah Siswa</label>
                                <input type="number" name="jmlh_siswa" id="jmlh_siswa" class="form-control" value="<%= data.jmlh_siswa %>" required>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small fw-bold">SPP (Rp)</label>
                                <input type="number" name="spp" id="spp" class="form-control" value="<%= data.spp %>" required>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small fw-bold">Durasi (Bulan)</label>
                                <select name="bulan" id="bulan" class="form-select">
                                    <option value="1" <%= data.bulan == 1 ? 'selected' : '' %>>1 Bulan</option>
                                    <option value="3" <%= data.bulan == 3 ? 'selected' : '' %>>3 Bulan</option>
                                    <option value="6" <%= data.bulan == 6 ? 'selected' : '' %>>6 Bulan</option>
                                </select>
                            </div>
                        </div>

                        <div class="form-check form-switch mb-4">
                            <input class="form-check-input" type="checkbox" name="is_ppdb_bersama" id="is_ppdb_bersama" 
                                <%= data.is_ppdb_bersama ? 'checked' : '' %> style="cursor: pointer;">
                            <label class="form-check-label fw-bold text-dark" for="is_ppdb_bersama">Berkas PPDB Bersama?</label>
                        </div>

                        <div class="mb-3 p-3 bg-info bg-opacity-10 border border-info rounded shadow-sm">
                            <label class="form-label small fw-bold text-info text-uppercase">Total Pendebetan (Dapat diedit manual)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-info text-white border-info">Rp</span>
                                <input type="text" id="total_display" class="form-control border-info fw-bold" required>
                                <input type="hidden" name="total" id="total_input">
                            </div>
                        </div>

                        <div class="d-grid gap-2 mt-4">
                            <button type="submit" class="btn btn-primary fw-bold py-2 shadow-sm">
                                <i class="bi bi-cloud-arrow-up"></i> SIMPAN PERUBAHAN
                            </button>
                            <a href="/dashboard" class="btn btn-link text-muted text-decoration-none small text-center">Batal dan Kembali</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    const form = document.getElementById('formEditSptjm');
    const totalDisplay = document.getElementById('total_display');
    const totalInput = document.getElementById('total_input');

    // Format Titik Ribuan
    const formatRibuan = (angka) => {
        return angka.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ".");
    };

    const bersihkanAngka = (teks) => {
        return teks.replace(/\./g, "").replace(/[^0-9]/g, "");
    };

    const calculateTotal = () => {
        const s = document.getElementById('jmlh_siswa').value || 0;
        const p = document.getElementById('spp').value || 0;
        const b = document.getElementById('bulan').value || 0;
        const hasil = s * p * b;
        
        totalDisplay.value = formatRibuan(hasil);
        totalInput.value = hasil;
    };

    // Saat User mengetik manual di input total
    totalDisplay.oninput = function() {
        let nilaiBersih = bersihkanAngka(this.value);
        this.value = formatRibuan(nilaiBersih);
        totalInput.value = nilaiBersih;
    };

    // Jalankan kalkulasi saat halaman dibuka (Prefill)
    window.onload = () => {
        const totalAwal = "<%= data.total %>";
        totalDisplay.value = formatRibuan(totalAwal);
        totalInput.value = totalAwal;
    };

    ['jmlh_siswa', 'spp', 'bulan'].forEach(id => {
        document.getElementById(id).oninput = calculateTotal;
    });

    form.onsubmit = async (e) => {
        e.preventDefault();
        const formData = new FormData(form);
        const body = Object.fromEntries(formData.entries());
        body.is_ppdb_bersama = document.getElementById('is_ppdb_bersama').checked;

        try {
            const res = await fetch(`/sptjm/<%= data.id %>`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(body)
            });
            
            const result = await res.json();
            if (result.status === 'success') {
                alert("Berhasil diperbarui!");
                window.location.href = '/dashboard';
            } else {
                alert("Gagal: " + result.message);
            }
        } catch (err) {
            alert("Kesalahan koneksi ke server.");
        }
    };
</script>