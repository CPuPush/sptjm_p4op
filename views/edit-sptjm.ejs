<div class="container mt-4 mb-5">
    <div class="card shadow-sm border-0">
        <div class="card-header bg-primary text-white py-3">
            <h5 class="mb-0 fw-bold"><i class="bi bi-pencil-square"></i> Edit Transaksi SPTJM</h5>
        </div>
        <div class="card-body p-4">
            <form id="formEditSptjm">
                <div class="mb-4 p-3 bg-light rounded border">
                    <label class="form-label fw-bold text-muted small text-uppercase">Sekolah</label>
                    <h5 class="fw-bold mb-0 text-dark"><%= data.AlokasiBantuan?.MasterSekolah?.nama_sekolah %></h5>
                    <small class="text-muted">Tahap <%= data.AlokasiBantuan?.tahap %> - <%= data.AlokasiBantuan?.tahun %></small>
                </div>

                <div class="row mb-3">
                    <div class="col-md-6">
                        <label class="form-label small">Nomor Surat</label>
                        <input type="text" name="no_surat" class="form-control" value="<%= data.no_surat %>" required>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small">Nama Penanggung Jawab</label>
                        <input type="text" name="nama" class="form-control" value="<%= data.nama %>" required>
                    </div>
                </div>

                <div class="row mb-3">
                    <div class="col-md-4">
                        <label class="form-label small">Jumlah Siswa</label>
                        <input type="number" name="jmlh_siswa" id="jmlh_siswa" class="form-control" value="<%= data.jmlh_siswa %>" required>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small">SPP (Rp)</label>
                        <input type="number" name="spp" id="spp" class="form-control" value="<%= data.spp %>" required>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label small">Bulan</label>
                        <select name="bulan" id="bulan" class="form-select">
                            <option value="1" <%= data.bulan == 1 ? 'selected' : '' %>>1 Bulan</option>
                            <option value="3" <%= data.bulan == 3 ? 'selected' : '' %>>3 Bulan</option>
                            <option value="6" <%= data.bulan == 6 ? 'selected' : '' %>>6 Bulan</option>
                        </select>
                    </div>
                </div>

                <div class="d-grid gap-2 mt-4">
                    <button type="submit" class="btn btn-primary fw-bold py-2">SIMPAN PERUBAHAN</button>
                    <a href="/dashboard" class="btn btn-link text-muted text-decoration-none">Kembali</a>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    const form = document.getElementById('formEditSptjm');
    form.onsubmit = async (e) => {
        e.preventDefault();
        const formData = new FormData(form);
        const body = Object.fromEntries(formData.entries());

        try {
            const res = await fetch(`/sptjm/<%= data.id %>`, {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(body)
            });
            const result = await res.json();
            if (result.status === 'success') {
                alert("Data berhasil diperbarui!");
                window.location.href = '/dashboard';
            } else {
                alert("Gagal: " + result.message);
            }
        } catch (err) {
            alert("Terjadi kesalahan koneksi.");
        }
    };
</script>